+/* Replaces page file picker dialogs with a main-process controlled file selection. */
+
+var fileInputPickerRequests = new WeakSet()
+
+function isFileInput (element) {
+  return element && element.tagName === 'INPUT' && element.type === 'file'
+}
+
+function findFileInputInPath (event) {
+  var path = typeof event.composedPath === 'function' ? event.composedPath() : []
+
+  for (var i = 0; i < path.length; i++) {
+    if (isFileInput(path[i])) {
+      return path[i]
+    }
+  }
+
+  return null
+}
+
+function findFileInputTarget (event) {
+  var pathInput = findFileInputInPath(event)
+  if (pathInput) {
+    return pathInput
+  }
+
+  var target = event.target
+
+  if (isFileInput(target)) {
+    return target
+  }
+
+  if (target && typeof target.closest === 'function') {
+    var label = target.closest('label')
+
+    if (label) {
+      if (label.control && isFileInput(label.control)) {
+        return label.control
+      }
+
+      return label.querySelector('input[type=file]')
+    }
+
+    if (target.tagName === 'LABEL' && target.htmlFor && target.ownerDocument) {
+      var labelledInput = target.ownerDocument.getElementById(target.htmlFor)
+
+      if (isFileInput(labelledInput)) {
+        return labelledInput
+      }
+    }
+  }
+
+  return null
+}
+
+function cancelNativeFilePicker (event) {
+  event.preventDefault()
+  event.stopImmediatePropagation()
+}
+
+async function pickFileForInput (input) {
+  if (fileInputPickerRequests.has(input)) {
+    return
+  }
+
+  fileInputPickerRequests.add(input)
+
+  try {
+    var result = await ipc.invoke('pick-file', {
+      accept: input.accept,
+      multiple: input.multiple
+    })
+
+    if (!result || result.canceled) {
+      return
+    }
+
+    var file = new File([result.data], result.name, {
+      lastModified: result.lastModified,
+      type: result.type
+    })
+
+    var dataTransfer = new DataTransfer()
+    dataTransfer.items.add(file)
+    input.files = dataTransfer.files
+
+    input.dispatchEvent(new Event('input', { bubbles: true }))
+    input.dispatchEvent(new Event('change', { bubbles: true }))
+  } catch (e) {
+    console.error('Unable to replace the file picker result.', e)
+  } finally {
+    fileInputPickerRequests.delete(input)
+  }
+}
+
+function handleFileInputActivation (event) {
+  var input = findFileInputTarget(event)
+  if (!input) {
+    return
+  }
+
+  cancelNativeFilePicker(event)
+  pickFileForInput(input)
+}
+
+function blockFileInputEvent (event) {
+  var input = findFileInputTarget(event)
+  if (!input) {
+    return
+  }
+
+  cancelNativeFilePicker(event)
+}
+
+function isFileInputActivationKey (event) {
+  return event.key === 'Enter' || event.key === ' ' || event.key === 'Spacebar'
+}
+
+window.addEventListener('click', handleFileInputActivation, true)
+window.addEventListener('auxclick', handleFileInputActivation, true)
+window.addEventListener('mousedown', blockFileInputEvent, true)
+window.addEventListener('mouseup', blockFileInputEvent, true)
+window.addEventListener('touchstart', handleFileInputActivation, true)
+window.addEventListener('keydown', function (event) {
+  if (isFileInputActivationKey(event)) {
+    handleFileInputActivation(event)
+  }
+}, true)

